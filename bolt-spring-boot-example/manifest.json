{
  "_metadata": {
    "major_version": 2,
    "minor_version": 1
  },
  "display_information": {
    "name": "Bolt Spring Boot Example",
    "description": "Example Slack app demonstrating the Bolt Spring Boot starter",
    "background_color": "#2c2d30"
  },
  "features": {
    "bot_user": {
      "display_name": "Bolt Example",
      "always_online": false
    },
    "shortcuts": [
      {
        "name": "Open Feedback Form",
        "type": "global",
        "callback_id": "open-feedback-form",
        "description": "Opens a modal to submit feedback"
      }
    ],
    "slash_commands": [
      {
        "command": "/hello",
        "url": "https://f3ca-72-49-245-185.ngrok-free.app/slack/events",
        "description": "Get a greeting",
        "should_escape": false
      },
      {
        "command": "/log",
        "url": "https://f3ca-72-49-245-185.ngrok-free.app/slack/events",
        "description": "Log a message (no visible response)",
        "usage_hint": "[message]",
        "should_escape": false
      },
      {
        "command": "/echo",
        "url": "https://f3ca-72-49-245-185.ngrok-free.app/slack/events",
        "description": "Echo back your message",
        "usage_hint": "[text]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "chat:write",
        "commands"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://f3ca-72-49-245-185.ngrok-free.app/slack/events",
      "bot_events": [
        "app_mention",
        "message.channels"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://f3ca-72-49-245-185.ngrok-free.app/slack/events"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
